{
  "policy_name": "s3-block-public-access-bucket-level",
  "description": "This policy verifies that all S3 buckets have public access block settings properly configured with all four conditions enabled",
  "enforcement_level": "mandatory",
  "attributes": {
    "resource_types": [
      "aws_s3_bucket",
      "aws_s3_bucket_public_access_block"
    ],
    "conditions": [
      "block_public_acls = true",
      "ignore_public_acls = true",
      "block_public_policy = true",
      "restrict_public_buckets = true"
    ]
  },
  "reference_url": "https://docs.aws.amazon.com/securityhub/latest/userguide/s3-controls.html#s3-8"
}
